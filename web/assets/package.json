{
  "private": true,
  "scripts": {
    "copy": "copyfiles -u 1 'static/**/*' ../priv/static",
    "esbuild": "node ./build.js",
    "watch": "NODE_ENV=development sh -c 'npm run copy & npm run esbuild -- --watch'",
    "deploy": "NODE_ENV=production sh -c 'npm run copy & npm run esbuild'"
  },
  "dependencies": {
    "@codemirror/commands": "^6.1.1",
    "@lezer/highlight": "^1.1.1",
    "@lezer/javascript": "^1.0.2",
    "@codemirror/lang-javascript": "^6.1.0",
    "@codemirror/language": "^6.2.1",
    "@codemirror/state": "^6.1.2",
    "@codemirror/view": "^6.3.0",
    "@ddietr/codemirror-themes": "^1.0.8",
    "@fortawesome/fontawesome-free": "^6.2.0",
    "phoenix": "file:../deps/phoenix",
    "phoenix_html": "file:../deps/phoenix_html",
    "phoenix_live_view": "file:../deps/phoenix_live_view",
    "topbar": "^1.0.0"
  },
  "devDependencies": {
    "bulma": "^0.9.3",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.0",
    "esbuild-sass-plugin": "^3.0.0"
  },
  "engines": {
    "node": ">=14.x"
  }
}
